# ══════════════════════════════════════════════════════════════
#  SmartChunaav AI – Backend Environment Variables
#  Copy this file to .env and fill in your values.
#  NEVER commit .env to version control.
# ══════════════════════════════════════════════════════════════

# ── Google Cloud / Vertex AI (REQUIRED) ──────────────────────
# Your GCP project that has Vertex AI API enabled.
GCP_PROJECT=numeric-analogy-492305-c6

# Vertex AI serving location. 'global' works for most Gemini models.
GCP_LOCATION=global

# Gemini model identifier. Options: gemini-2.0-flash, gemini-1.5-pro-002
GEMINI_MODEL=gemini-2.0-flash

# ── CORS (REQUIRED in production) ────────────────────────────
# Comma-separated list of allowed frontend origins.
# Development: http://localhost:3000
# Production:  https://smartchunaav.yourapp.com
CORS_ORIGINS=http://localhost:3000

# ── App ───────────────────────────────────────────────────────
APP_ENV=development
APP_NAME=SmartChunaav AI
